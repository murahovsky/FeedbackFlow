    "submit_feedback.success_message" : {
      "comment" : "submit_feedback.success_message",
      "extractionState" : "manual",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din anmodning er sendt.\nVi gennemgår den snart."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Anfrage wurde gesendet.\nWir prüfen sie in Kürze."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your request has been submitted.\nWe'll review it shortly."
          }
